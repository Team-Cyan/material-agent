# syntax=docker/dockerfile:1.7

ARG AGENT_PYTHON_UV_BASE=ghcr.io/astral-sh/uv:python3.14-trixie
FROM ${AGENT_PYTHON_UV_BASE}

ARG VERSION=0.4.0
ARG REVISION=unknown
ARG BUILD_DATE=unknown

LABEL org.opencontainers.image.title="material-agent" \
    org.opencontainers.image.description="NAS-first local photo culling and scoring agent with Intel OpenVINO runtime" \
    org.opencontainers.image.version="${VERSION}" \
    org.opencontainers.image.revision="${REVISION}" \
    org.opencontainers.image.created="${BUILD_DATE}"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/usr/local \
    MATERIAL_AGENT_CONFIG=/app/config/config.yaml \
    MATERIAL_AGENT_WORK_DIR=/app/.material-agent

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        libimage-exiftool-perl \
        libgl1 \
        libglib2.0-0 \
        ocl-icd-libopencl1 \
        libze1 \
    && mkdir -p /tmp/intel-gpu \
    && cd /tmp/intel-gpu \
    && curl -fLO https://github.com/intel/intel-graphics-compiler/releases/download/v2.36.3/intel-igc-core-2_2.36.3+21719_amd64.deb \
    && curl -fLO https://github.com/intel/intel-graphics-compiler/releases/download/v2.36.3/intel-igc-opencl-2_2.36.3+21719_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/intel-ocloc_26.22.38646.4-0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/intel-opencl-icd_26.22.38646.4-0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/libigdgmm12_22.10.0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/libze-intel-gpu1_26.22.38646.4-0_amd64.deb \
    && apt-get install -y --no-install-recommends ./*.deb \
    && rm -rf /tmp/intel-gpu /var/lib/apt/lists/*

ARG DINOV3_REVISION=48988dfe73065df8d6f5ccc0edc7c8bcf307de41
RUN mkdir -p /opt/material-agent/models/dinov3-vits16/onnx \
    && curl -fL "https://huggingface.co/onnx-community/dinov3-vits16-pretrain-lvd1689m-ONNX/resolve/${DINOV3_REVISION}/onnx/model_quantized.onnx" \
        -o /opt/material-agent/models/dinov3-vits16/onnx/model_quantized.onnx \
    && curl -fL "https://huggingface.co/onnx-community/dinov3-vits16-pretrain-lvd1689m-ONNX/resolve/${DINOV3_REVISION}/onnx/model_quantized.onnx_data" \
        -o /opt/material-agent/models/dinov3-vits16/onnx/model_quantized.onnx_data \
    && curl -fL "https://huggingface.co/onnx-community/dinov3-vits16-pretrain-lvd1689m-ONNX/resolve/${DINOV3_REVISION}/preprocessor_config.json" \
        -o /opt/material-agent/models/dinov3-vits16/preprocessor_config.json

COPY pyproject.toml uv.lock README.md /app/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra intel-openvino \
        --extra local-models \
        --extra quality-models \
        --extra face-models \
        --no-dev --no-editable --no-install-project

COPY src /app/src
COPY docker /app/docker
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra intel-openvino \
        --extra local-models \
        --extra quality-models \
        --extra face-models \
        --no-dev --no-editable \
    && chmod +x /app/docker/entrypoint.sh

ENTRYPOINT ["/app/docker/entrypoint.sh"]
