# syntax=docker/dockerfile:1.7

ARG AGENT_PYTHON_UV_BASE=ghcr.io/astral-sh/uv:python3.14-trixie@sha256:12a46aa8066ea9ab1236ccaa6ad02086e375d3b70830d05797f123eedabb2294
FROM ${AGENT_PYTHON_UV_BASE}

ARG VERSION=0.4.0
ARG REVISION=unknown
ARG BUILD_DATE=unknown

LABEL org.opencontainers.image.title="material-agent" \
    org.opencontainers.image.description="NAS-first local photo culling and scoring agent with Intel OpenVINO runtime" \
    org.opencontainers.image.version="${VERSION}" \
    org.opencontainers.image.revision="${REVISION}" \
    org.opencontainers.image.created="${BUILD_DATE}"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/usr/local \
    PUID=1000 \
    PGID=1000 \
    MATERIAL_AGENT_CONFIG=/app/config/config.yaml \
    MATERIAL_AGENT_WORK_DIR=/config

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        findutils \
        gosu \
        intel-gpu-tools \
        libcap2-bin \
        libimage-exiftool-perl \
        libgl1 \
        libglib2.0-0 \
        passwd \
        ocl-icd-libopencl1 \
        libze1 \
    && mkdir -p /tmp/intel-gpu \
    && cd /tmp/intel-gpu \
    && curl -fLO https://github.com/intel/intel-graphics-compiler/releases/download/v2.36.3/intel-igc-core-2_2.36.3+21719_amd64.deb \
    && curl -fLO https://github.com/intel/intel-graphics-compiler/releases/download/v2.36.3/intel-igc-opencl-2_2.36.3+21719_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/intel-ocloc_26.22.38646.4-0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/intel-opencl-icd_26.22.38646.4-0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/libigdgmm12_22.10.0_amd64.deb \
    && curl -fLO https://github.com/intel/compute-runtime/releases/download/26.22.38646.4/libze-intel-gpu1_26.22.38646.4-0_amd64.deb \
    && printf '%s  %s\n' \
        '9e0975ac75015b431ebb2da81a802b9fd1e28a3c270313a97569cd1e6a6c6048' 'intel-igc-core-2_2.36.3+21719_amd64.deb' \
        '350a52331e784bb7fb9ed42e993b5c44b7e6562fc74d2cf3102b29b6a576fa85' 'intel-igc-opencl-2_2.36.3+21719_amd64.deb' \
        '25745841e66279c7ff1ff6c2d4da9ec911685c12e1c9c5609d99e4d54a364dc0' 'intel-ocloc_26.22.38646.4-0_amd64.deb' \
        '6fdac2e8a2aacf844ebfd90521bf7102b3ebb44f69c1bced1a9785a7ce96a3c2' 'intel-opencl-icd_26.22.38646.4-0_amd64.deb' \
        '6031a63d6e8a12ce61c14efc15f2c8e727061286e3820b8594e6d00615e04d54' 'libigdgmm12_22.10.0_amd64.deb' \
        '8bef9f24e03f826f93c076081bda13c6ac3afbd9e42b9fb8f298fab652330e2f' 'libze-intel-gpu1_26.22.38646.4-0_amd64.deb' \
        | sha256sum --check --strict - \
    && apt-get install -y --no-install-recommends ./*.deb \
    && groupadd --gid 1000 material-agent \
    && useradd --uid 1000 --gid material-agent --create-home \
        --home-dir /home/material-agent --shell /usr/sbin/nologin material-agent \
    && install -d -m 0755 -o material-agent -g material-agent /config \
    && setcap cap_perfmon=ep /usr/bin/intel_gpu_top \
    && rm -rf /tmp/intel-gpu /var/lib/apt/lists/*

ARG NIMA_REVISION=15308061b353e9ef1de4c9d33b8f0fab0a7e350e
RUN mkdir -p /opt/material-agent/models/nima \
    && curl -fL "https://huggingface.co/litert-community/NIMA-LiteRT/resolve/${NIMA_REVISION}/nima_aesthetic_fp16.tflite" \
        -o /opt/material-agent/models/nima/nima_aesthetic_fp16.tflite \
    && printf '%s  %s\n' \
        'a5051a0fcced735682735e3e0fd58ee54c83ed664282a003f52235b3dbcb9320' '/opt/material-agent/models/nima/nima_aesthetic_fp16.tflite' \
        | sha256sum --check --strict -

# SSD MobileNet V1 provides compact COCO object localization without a YOLO,
# CLIP, Torch, or TensorFlow runtime. YuNet adds face and eye landmarks used by
# the subject-focus pass. Both assets are checksum-pinned for reproducibility.
ARG SSD_MOBILENET_REVISION=019281f3fcb151a90e491f3b2f0273f9f31bd6be
ARG YUNET_REVISION=3cc26e7f1014a5ee5d74a42acee58bafc9d0a310
RUN mkdir -p /opt/material-agent/models/detection \
    && curl -fL "https://huggingface.co/onnxmodelzoo/ssd_mobilenet_v1_12/resolve/${SSD_MOBILENET_REVISION}/ssd_mobilenet_v1_12.onnx" \
        -o /opt/material-agent/models/detection/ssd_mobilenet_v1_12.onnx \
    && curl -fL "https://huggingface.co/opencv/face_detection_yunet/resolve/${YUNET_REVISION}/face_detection_yunet_2023mar_int8.onnx" \
        -o /opt/material-agent/models/detection/face_detection_yunet_2023mar_int8.onnx \
    && printf '%s  %s\n' \
        'b8fba5e404077d4048d27fcd1667e85e27e192eb9bf51e696c46a3acd7d21058' '/opt/material-agent/models/detection/ssd_mobilenet_v1_12.onnx' \
        '321aa5a6afabf7ecc46a3d06bfab2b579dc96eb5c3be7edd365fa04502ad9294' '/opt/material-agent/models/detection/face_detection_yunet_2023mar_int8.onnx' \
        | sha256sum --check --strict -

COPY pyproject.toml uv.lock /app/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra intel-openvino \
        --no-dev --no-editable --no-install-project

COPY README.md /app/README.md
COPY docker/config.intel-openvino.yaml /app/config/config.yaml
COPY src /app/src
COPY docker /app/docker
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra intel-openvino \
        --no-dev --no-editable \
    && chmod +x /app/docker/entrypoint.sh

ENTRYPOINT ["/app/docker/entrypoint.sh"]
