# syntax=docker/dockerfile:1.7

ARG AGENT_PYTHON_UV_BASE=ghcr.io/astral-sh/uv:python3.14-trixie@sha256:12a46aa8066ea9ab1236ccaa6ad02086e375d3b70830d05797f123eedabb2294
FROM ${AGENT_PYTHON_UV_BASE}

ARG VERSION=0.4.0
ARG REVISION=unknown
ARG BUILD_DATE=unknown

LABEL org.opencontainers.image.title="material-agent" \
    org.opencontainers.image.description="NAS-first local photo culling and scoring agent" \
    org.opencontainers.image.version="${VERSION}" \
    org.opencontainers.image.revision="${REVISION}" \
    org.opencontainers.image.created="${BUILD_DATE}"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/usr/local \
    PUID=1000 \
    PGID=1000 \
    MATERIAL_AGENT_CONFIG=/app/config/config.yaml \
    MATERIAL_AGENT_WORK_DIR=/app/.material-agent

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        findutils \
        gosu \
        libimage-exiftool-perl \
        libgl1 \
        libglib2.0-0 \
        passwd \
    && groupadd --gid 1000 material-agent \
    && useradd --uid 1000 --gid material-agent --create-home \
        --home-dir /home/material-agent --shell /usr/sbin/nologin material-agent \
    && install -d -m 0755 -o material-agent -g material-agent /app/.material-agent \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock /app/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra cpu \
        --no-dev --no-editable --no-install-project

COPY README.md /app/README.md
COPY config.yaml /app/config/config.yaml
COPY src /app/src
COPY docker /app/docker
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen \
        --extra cpu \
        --no-dev --no-editable \
    && chmod +x /app/docker/entrypoint.sh

ENTRYPOINT ["/app/docker/entrypoint.sh"]
